"value":"1020666"},{"name":"content-security-policy-report-only","value":"script-src 'self' translate.googleapis.com translate.google.com www.google-analytics.com static.mcc.miui.com connect.facebook.net shopee.sg images.uc.cn g.alicdn.com blob:; object-src 'none'; report-uri https://secreporter.susercontent.com/csp"},{"name":"x-cdn","value":"aws"}],"content":{"size":2819,"mimeType":"application/json","text":"{\"label_ac_btn_bind_phone\":\"Hubungkan No. HP\",\"label_ac_btn_login_app\":\"Log In di Aplikasi Shopee\",\"label_ac_error_failed_btn\":\"Coba Lagi\",\"label_ac_error_failed_report\":\"Permasalahan Gagal Dilaporkan\",\"label_ac_error_login_report_issue_btn\":\"Log In dan Laporkan\",\"label_ac_error_page_unavailable\":\"Halaman Tidak Tersedia\",\"label_ac_error_report_issue_btn\":\"Laporkan Permasalahan\",\"label_ac_error_request_id\":\"ID:\",\"label_ac_error_successful_report\":\"Permasalahan Berhasil Dilaporkan\",\"label_ac_error_sucessful_btn\":\"Kembali ke Halaman Utama\",\"label_ac_error_sucessful_btn_login\":\"Log In\",\"label_ac_error_sucessful_btn_logout\":\"Log Out\",\"label_ac_title_bind_phone\":\"Silakan Hubungkan No. HP Kamu\",\"label_ac_title_sms_otp\":\"Kamu Telah Log Out\",\"msg_ac_error_bind_phone\":\"Untuk lanjut mengakses Shopee, silakan hubungkan no. HP dengan akun Shopee kamu. Jika no. HP kamu sudah dihubungkan, mohon tunggu beberapa menit hingga perubahan berlaku. Terima kasih atas kesabarannya.\",\"msg_ac_error_failed_message\":\"Mohon coba lagi. Jika masih terjadi, tunggu dalam beberapa menit dan coba kembali.\",\"msg_ac_error_login_app\":\"Untuk tetap dapat menggunakan Shopee, silakan download aplikasi Shopee dan log in ke akunmu.\",\"msg_ac_error_login_app_btn\":\"Ke Aplikasi Shopee\",\"msg_ac_error_login_issue\":\"Sepertinya Anda belum masuk. Masuk untuk melanjutkan atau kembali ke beranda.\",\"msg_ac_error_login_issue_xiapibuy\":\"Sepertinya Anda belum masuk. Silakan masuk untuk melanjutkan.\",\"msg_ac_error_sms_otp\":\"Maaf, terjadi kesalahan. Untuk lanjut mengakses Shopee, silakan kembali log in dengan No. HP kamu.\",\"msg_ac_error_successful_message\":\"Kami sedang memperbaiki masalah ini. Terima kasih atas kesabaranmu.\",\"msg_ac_error_unknown_issue\":\"Maaf. telah terjadi kesalahan. Silakan kembali dan coba lagi atau kembali ke Halaman Utama.\",\"msg_ac_error_unknown_issue_1\":\"Aktivitas akunmu sementara dibatasi karena aktivitas mencurigakan. Pelanggaran yang terus berlanjut dapat menyebabkan akunmu diblokir permanen. Jika kamu rasa ini adalah kesalahan, silakan hubungi CS.\",\"msg_ac_error_unknown_issue_2\":\"Agar pesanan yang sama tidak terbuat dua kali, silakan cek dan konfirmasi pesananmu lagi nanti.\",\"msg_ac_error_unknown_issue_3\":\"Mohon perbarui Aplikasi Shopee ke versi terbaru dan coba lagi setelah 5 menit.\",\"msg_ac_error_unknown_issue_login\":\"Maaf, telah terjadi kesalahan. Silakan log in dan coba lagi atau kembali ke Halaman Utama.\",\"msg_ac_error_unknown_issue_login_xiapibuy\":\"Maaf, kamu hanya dapat log in ke Xiapibuy dengan IP CN. Silakan perbarui aplikasi ke versi terbaru dan coba lagi. Jika kamu belum dapat log in, silakan laporkan ke Customer Service.\",\"msg_ac_error_unknown_issue_xiapibuy\":\"Maaf, telah terjadi kesalahan. Silakan coba lagi atau hubungi Customer Service untuk melaporkan jika kamu terus mengalami kendala.\"}"},"redirectURL":"","headersSize":1211,"bodySize":951,"_status":"completed","_startTimestamp":1781472441683268,"_endTimestamp":1781472441684788},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"18.161.49.44","connection":"155","comment":"","_id":313,"_uid":"477de43c-c487-457f-8650-d4d7f2da4021","_cid":155,"_ctime":1781472440063,"_sid":67,"_stime":1781472441421,"_serverAddress":"18.161.49.44","_serverAddressFamily":0,"_serverPort":443,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":46632},{"startedDateTime":"2026-06-14T21:27:21.367Z","time":315,"request":{"method":"GET","url":"https://deo.shopeemobil